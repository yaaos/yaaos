#!/usr/bin/env python3
"""Ban `mock.patch` / `mocker.patch` / `unittest.mock.patch` in tests.

Per `plan/milestones/M01-code-review/patterns.md` § DI over @patch: substitute
dependencies via dependency injection, not via patching globals. Files may opt
out with a `# override-patch-prevention:file` comment (with a one-line reason).
"""

from __future__ import annotations

import ast
import sys
from pathlib import Path

REPO = Path(__file__).resolve().parents[1]

BANNED_QUALNAMES = {
    "unittest.mock.patch",
    "mock.patch",
    "mocker.patch",
}


def file_is_opted_out(path: Path) -> bool:
    try:
        head = path.read_text().splitlines()[:20]
    except Exception:
        return False
    return any("override-patch-prevention:file" in line for line in head)


def check_file(path: Path) -> list[str]:
    violations: list[str] = []
    if file_is_opted_out(path):
        return violations
    try:
        tree = ast.parse(path.read_text(), filename=str(path))
    except SyntaxError:
        return violations

    for node in ast.walk(tree):
        # `mock.patch(...)` / `mocker.patch(...)`
        if isinstance(node, ast.Attribute) and node.attr == "patch":
            value = node.value
            if isinstance(value, ast.Name) and value.id in {"mock", "mocker"}:
                violations.append(f"{path}:{node.lineno}: {value.id}.patch is banned")
            elif (
                isinstance(value, ast.Attribute)
                and value.attr == "mock"
                and isinstance(value.value, ast.Name)
                and value.value.id == "unittest"
            ):
                violations.append(f"{path}:{node.lineno}: unittest.mock.patch is banned")
        # `from unittest.mock import patch` / `from mock import patch`
        if isinstance(node, ast.ImportFrom):
            mod = node.module or ""
            if mod in {"unittest.mock", "mock"} and any(a.name == "patch" for a in node.names):
                violations.append(f"{path}:{node.lineno}: `from {mod} import patch` is banned")

    return violations


def main() -> int:
    test_files = list(REPO.rglob("test_*.py")) + list(REPO.rglob("conftest.py"))
    # Exclude .venv and any node_modules.
    test_files = [
        p for p in test_files if ".venv" not in p.parts and "node_modules" not in p.parts
    ]

    all_violations: list[str] = []
    for path in test_files:
        all_violations.extend(check_file(path))

    if all_violations:
        print("error: `patch` is banned in tests — use dependency injection instead.", file=sys.stderr)
        for v in all_violations:
            print(f"  {v}", file=sys.stderr)
        print("(opt out a single file with `# override-patch-prevention:file` in the first 20 lines.)", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
