#!/usr/bin/env bash
# Rebuild SPA + dev docker image, then start the stack.
# Use after any source code change (backend Python, frontend SPA,
# pyproject.toml, package.json, Dockerfile). Use bin/dev-restart
# for env-only changes (no rebuild).
#
# The SPA build is critical: apps/web/dist/ is bind-mounted from the
# host, so the running container always reads the on-disk bundle. A
# fresh React change requires `pnpm build` here or the browser will
# keep serving the previous build.

set -euo pipefail

cd "$(dirname "$0")/.."

# pnpm install runs first so local node_modules tracks pnpm-lock.yaml on
# every rebuild — matches what RWX's ci-web does on every CI run. Without
# this, a teammate'\''s newly-added dependency lands on disk via git pull but
# never reaches node_modules, and the next tsc step fails with a cryptic
# "Cannot find module" before vite even runs.
echo "==> Syncing pnpm workspace (matches RWX ci-web)"
pnpm install --frozen-lockfile

echo "==> Building SPA (apps/web/dist/)"
pnpm --filter ./apps/web build

echo "==> Rebuilding backend image + starting stack (postgres, redis, mailpit, app, worker, agent)"
docker compose \
  -f docker/docker-compose.dev.yml \
  --env-file .env \
  up -d --build
