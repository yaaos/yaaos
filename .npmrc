# Put pnpm's content-addressable store inside the workspace so RWX task
# layers capture it. The default ~/.local/share/pnpm/store lives outside
# the workspace and doesn't travel across `use:`d tasks, leaving
# node_modules symlinks dangling. With this setting, downstream tasks
# that mount the pnpm-install layer see a self-contained store.
store-dir=.pnpm-store

# Use file copies (not hardlinks) from the store into node_modules/.pnpm/.
# RWX's task-layer capture doesn't preserve the hardlink relationship —
# under the default `auto` (hardlink-preferred), downstream tasks end up
# with binaries missing from node_modules even though the store has them.
# Costs ~2x disk inside the layer; cheap relative to RWX cache hits.
package-import-method=copy
