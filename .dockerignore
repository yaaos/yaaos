# Keep the Fly remote-builder context small and out of the image.
# The backend Dockerfile builds the SPA (apps/web) + backend (apps/backend)
# from the repo root; everything below is irrelevant to that build.

.git
**/node_modules
**/.venv
**/__pycache__
**/*.pyc
**/tmp
**/dist
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache

# Planning scaffolding — gitignored working docs, never part of the image.
plan/

# Local tooling / editor noise. Carve-out: pipeline-* skills + agents are
# a required web-build input (apps/web/bin/build-skills-bundle bundles
# them into the static yaaos-pipeline-skills.zip download) — the
# web-builder Docker stage needs them in the build context. Docker can't
# re-include a path whose parent directory was fully excluded, so the
# exclude/re-include pairs below walk down one level at a time rather
# than excluding `.claude` outright.
.claude/*
!.claude/skills
!.claude/agents
.claude/skills/*
!.claude/skills/pipeline-*
.claude/agents/*
!.claude/agents/pipeline-*.md
.idea
.vscode
*.log
.DS_Store
