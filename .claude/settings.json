{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)",
      "Bash",
      "Skill(*)",
      "Skill",
      "Agent(*)",
      "Agent",
      "Task(*)",
      "Task",
      "WebFetch",
      "WebSearch",
      "Read",
      "Grep",
      "Glob",
      "Write",
      "Edit",
      "TodoWrite"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(shred *)",
      "Bash(truncate *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git clean *)",
      "Bash(docker system prune *)",
      "Bash(chmod -R *)"
    ]
  }
}
