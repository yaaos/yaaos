# Copy to .env (or .env.dev.local) and edit. See plan/milestones/M01-code-review/architecture.md
# § "Boot-time environment variables" for the canonical list.

# REQUIRED ----------------------------------------------------------------

# Async Postgres URL.
DATABASE_URL=postgresql+asyncpg://yaaos:yaaos@localhost:5432/yaaos

# 32 bytes URL-safe base64 — Fernet key for credential encryption at rest.
# Generate once at install:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Persist out-of-band (secrets manager / 1Password). Losing this key requires
# re-entering credentials via the Settings UI; the encrypted source data is
# itself recoverable from Anthropic + GitHub.
YAAOS_ENCRYPTION_KEY=

# The yaaos GitHub *App* — drives the per-customer-org install flow only.
# Create once at https://github.com/settings/apps/new with:
#   - Setup URL:    http://localhost:8080/api/github/install_callback
#   - Webhook URL:  http://localhost:8080/api/github/webhook
# Install is disabled silently when these are unset.
#
# PRIVATE_KEY: paste the PEM as one line with literal `\n` between rows —
# the backend normalizes them back to real newlines before signing.
# Example:
#   YAAOS_GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBA...\n...\n-----END PRIVATE KEY-----\n
YAAOS_GITHUB_APP_ID=
YAAOS_GITHUB_APP_SLUG=
YAAOS_GITHUB_APP_PRIVATE_KEY=
YAAOS_GITHUB_APP_WEBHOOK_SECRET=

# The yaaos GitHub *OAuth App* — drives "Sign in with GitHub". This is a
# DIFFERENT GitHub primitive from the GitHub App above (GitHub names them
# confusingly). Create once at https://github.com/settings/developers →
# "New OAuth App" with:
#   - Authorization callback URL: http://localhost:8080/api/auth/callback/github
# Sign-in is disabled silently when these are unset.
YAAOS_GITHUB_OAUTH_CLIENT_ID=
YAAOS_GITHUB_OAUTH_CLIENT_SECRET=

# Signing secrets for short-lived state/invite tokens. Any high-entropy string;
# rotate by changing the value (in-flight tokens become invalid).
YAAOS_OAUTH_STATE_SECRET=
YAAOS_INVITATION_TOKEN_SECRET=

# Fernet key used to encrypt per-user TOTP seeds at rest. Same format as
# YAAOS_ENCRYPTION_KEY (32-byte URL-safe base64). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
YAAOS_TOTP_MASTER_KEY=

# OPTIONAL ----------------------------------------------------------------

# One of `dev` / `production`. Affects CORS defaults (permissive in dev), rate limiting, cookie Secure flag.
APP_MODE=dev

# Deployment tier tag for telemetry (OTel deployment.environment.name). REQUIRED — no default.
# Free-form: `local`, `development`, `staging`, `production`, or any new tier name.
ENVIRONMENT=local

# HTTP port FastAPI binds to.
YAAOS_PORT=8080

# Comma-separated allowed origins when APP_MODE != dev. Ignored in dev (allows *).
# YAAOS_CORS_ORIGINS=https://yaaos.example.com,https://yaaos.internal

# Dash0 OTLP/HTTP destination. All four must be set for the backend to attach
# OTLP exporters; any unset value silently skips exporters (providers exist but
# discard signals). Endpoint + dataset are non-secret; the two bearer tokens are
# secrets and serve distinct principals (backend vs. agent) — never swap them.
# YAAOS_DASH0_ENDPOINT=https://ingress.us-west-2.aws.dash0.com
# YAAOS_DASH0_DATASET=default
# YAAOS_BACKEND_DASH0_BEARER_TOKEN=
# YAAOS_AGENT_DASH0_BEARER_TOKEN=

# structlog / stdlib log level.
LOG_LEVEL=INFO
