# Copy to .env (or .env.dev.local) and edit. See plan/milestones/M01-code-review/architecture.md
# § "Boot-time environment variables" for the canonical list.

# REQUIRED ----------------------------------------------------------------

# Async Postgres URL.
DATABASE_URL=postgresql+asyncpg://yaaof:yaaof@localhost:5432/yaaof

# 32 bytes URL-safe base64 — Fernet key for credential encryption at rest.
# Generate once at install:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Persist out-of-band (secrets manager / 1Password). Losing this key requires
# re-entering credentials via the Settings UI; the encrypted source data is
# itself recoverable from Anthropic + GitHub.
YAAOF_ENCRYPTION_KEY=

# OPTIONAL ----------------------------------------------------------------

# One of `dev` / `prod`. Affects CORS defaults (permissive in dev), log formatting.
YAAOF_ENV=dev

# HTTP port FastAPI binds to.
YAAOF_PORT=8080

# Comma-separated allowed origins when YAAOF_ENV != dev. Ignored in dev (allows *).
# YAAOF_CORS_ORIGINS=https://yaaof.example.com,https://yaaof.internal

# OTLP endpoint for the OTel collector. If unset, OTel is disabled silently at boot.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name attribute on every span.
OTEL_SERVICE_NAME=yaaof

# structlog / stdlib log level.
LOG_LEVEL=INFO
