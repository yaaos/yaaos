#!/usr/bin/env bash
# e2e CI: brings up the test stack (Postgres pre-seeded + fake-github + yaaof),
# runs the Playwright suite against it, tears down. No external credentials
# required.
#
# The test stack is defined in docker/docker-compose.test.yml. It does NOT
# exist yet in the skeleton — it lands when `plugins/github` + `apps/fake-github`
# are built as part of M01. Until then this script reports the gap and exits 0.

set -euo pipefail

cd "$(dirname "$0")/.."

REPO_ROOT="$(git rev-parse --show-toplevel)"
COMPOSE_FILE="${REPO_ROOT}/docker/docker-compose.test.yml"

if [ ! -f "${COMPOSE_FILE}" ]; then
  echo "e2e test stack not yet built (docker-compose.test.yml missing) — skipping."
  echo "  This is expected during the skeleton phase; lands with M01 GitHub plugin."
  exit 0
fi

echo "==> docker compose up (test stack)"
docker compose -f "${COMPOSE_FILE}" up -d --wait

cleanup() {
  echo "==> docker compose down"
  docker compose -f "${COMPOSE_FILE}" down -v
}
trap cleanup EXIT

echo "==> playwright test"
pnpm exec playwright test
