#!/usr/bin/env bash
# Thin wrapper: resolve the apps/backend project root from the script's own
# location (cwd-independent), then exec the Python entry point under that
# project's uv venv so third-party deps (httpx, sqlalchemy, ...) resolve.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec uv run --project "$HERE" python "$HERE/bin/_bootstrap.py" "$@"
