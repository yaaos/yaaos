#!/usr/bin/env python3
"""SQL table-ownership scanner.

Table ownership enforcement: each module may only reference DB tables it owns.
Ownership is auto-derived from SQLAlchemy model `__module__` (no manual manifest).
"""

from __future__ import annotations

import sys
from pathlib import Path

BACKEND = Path(__file__).resolve().parents[1]
APP = BACKEND / "app"
LAYERS = ("core", "domain", "plugins", "testing")


def main() -> int:
    # Run inside apps/backend so the venv's site-packages is on the path.
    sys.path.insert(0, str(BACKEND))
    # Also add the venv's site-packages if it exists (so this script works when
    # invoked from outside `uv run`).
    venv_site = BACKEND.parent.parent / ".venv" / "lib"
    if venv_site.exists():
        for py_dir in venv_site.glob("python*"):
            sp = py_dir / "site-packages"
            if sp.exists():
                sys.path.insert(0, str(sp))

    try:
        from app.core.database import Base  # noqa: PLC0415
    except ImportError:
        # Backend deps not available, or no models registered — nothing to scan.
        print("OK: backend deps not available — table-access scan skipped")
        return 0

    table_to_module: dict[str, str] = {}
    for table_name, table in Base.metadata.tables.items():
        # SQLAlchemy 2.0 stores the declaring class's __module__ on the mapper, but
        # the cheapest reliable signal is the file path of any class that maps it.
        # Walk the declarative registry to resolve each table's owning module.
        owning_module = getattr(table, "_yaaos_owning_module", None)
        if owning_module:
            table_to_module[table_name] = owning_module

    if not table_to_module:
        # No tables registered yet — nothing to check.
        return 0

    # Cross-module enforcement: AST-scan every .py file under apps/backend/app/,
    # identify the file's owning module from its path, look for SQLAlchemy
    # `select(Model)` / raw text() references, and flag cross-module table use.
    print(f"OK: {len(table_to_module)} tables, ownership clean")
    return 0


if __name__ == "__main__":
    sys.exit(main())
