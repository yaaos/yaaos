#!/usr/bin/env python3
"""Cross-doc link checker.

Walks every markdown file under `docs/`, `apps/*/docs/`, plus `CLAUDE.md`,
and checks that every relative `[text](path)` link resolves to a file that
exists in the repo. Fails on any broken link.

What it DOES check:
- Relative file paths in markdown links (e.g. `[X](../foo/bar.md)`).
- Paths with line suffixes (e.g. `[X](path/to.py:42)`) — strips the `:42`
  before checking.
- Anchors are stripped (`#section`) — only file existence is verified, not
  heading existence.

What it does NOT check:
- `http://` / `https://` / `mailto:` URLs.
- Anchor validity (would need to parse target headings).
- Broken images.

Existence is checked against `git ls-files` when available — i.e. against
the *repo* contents, not the local filesystem. This decouples the check
from which subtrees happen to be mounted in the test environment (RWX's
backend-ci container ships `apps/backend/` + a few read-only doc-tree
mounts, but no source trees like `apps/web/src/`). Falling back to FS
when git isn't available keeps the script useful in stripped sandboxes.
"""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[3]  # apps/backend/bin/check_doc_links → repo root


def _git_tracked_paths() -> set[str] | None:
    """Repo-relative paths tracked by git, or None if git or `.git/` is unavailable.

    `-c safe.directory=*` disables the dubious-ownership guard. In CI the
    repo's `.git` is bind-mounted into a container that runs as a non-root
    user, so on Linux the in-container uid won't match the host uid that
    owns `.git` and git refuses to read it by default. Falling back to FS
    silently here would mask cross-app links into source trees that aren't
    mounted (e.g. `apps/web/src/`) — so any unexpected git failure is also
    surfaced to stderr instead of being swallowed.
    """
    try:
        out = subprocess.run(
            ["git", "-c", "safe.directory=*", "-C", str(REPO_ROOT), "ls-files"],
            check=True,
            capture_output=True,
            text=True,
            timeout=30,
        )
    except FileNotFoundError:
        return None
    except (subprocess.CalledProcessError, subprocess.TimeoutExpired) as e:
        stderr = getattr(e, "stderr", "") or ""
        sys.stderr.write(f"warning: `git ls-files` failed, falling back to FS check: {e}\n{stderr}\n")
        return None
    return set(out.stdout.splitlines())


def _target_exists(resolved: Path, tracked: set[str] | None) -> bool:
    """A target counts as present if git lists it OR (fallback) the FS has it.

    Many doc links point at directories (e.g. `../src/core/sidebar/`) — git
    doesn't track directories, only files, so we treat the target as
    present iff at least one tracked path lives under that prefix.
    """
    if tracked is not None:
        try:
            rel = resolved.relative_to(REPO_ROOT).as_posix()
        except ValueError:
            return resolved.exists()  # link escapes the repo — fall through
        if rel in tracked:
            return True
        prefix = rel.rstrip("/") + "/"
        return any(p.startswith(prefix) for p in tracked)
    return resolved.exists()

# Anchor file paths under these dirs:
DOC_GLOBS = [
    "docs/**/*.md",
    "apps/*/docs/**/*.md",
    "CLAUDE.md",
]

# [text](target) — non-greedy text + target, where target doesn't contain ) or whitespace.
LINK_RE = re.compile(r"\[(?P<text>[^\]]*?)\]\((?P<target>[^)\s]+)\)")


def is_external(target: str) -> bool:
    return target.startswith(("http://", "https://", "mailto:", "tel:", "#"))


def strip_anchor_and_line(target: str) -> str:
    """`foo.md#bar` → `foo.md`; `foo.py:42` → `foo.py`."""
    if "#" in target:
        target = target.split("#", 1)[0]
    if ":" in target:
        # Only strip `:<digits>` line suffix — leave `:` alone elsewhere (e.g. anchors in non-markdown targets).
        head, _, tail = target.rpartition(":")
        if tail.isdigit():
            target = head
    return target


def main() -> int:
    broken: list[tuple[Path, int, str]] = []
    tracked = _git_tracked_paths()

    files: list[Path] = []
    for glob in DOC_GLOBS:
        files.extend(REPO_ROOT.glob(glob))
    files = sorted(set(files))

    for file in files:
        try:
            text = file.read_text()
        except UnicodeDecodeError:
            continue
        for i, line in enumerate(text.splitlines(), start=1):
            for m in LINK_RE.finditer(line):
                target = m.group("target")
                if is_external(target) or not target:
                    continue
                cleaned = strip_anchor_and_line(target)
                if not cleaned:
                    continue
                resolved = (file.parent / cleaned).resolve()
                if not _target_exists(resolved, tracked):
                    broken.append((file.relative_to(REPO_ROOT), i, target))

    if broken:
        sys.stderr.write(f"\nBroken doc links ({len(broken)}):\n")
        for path, line, target in broken:
            sys.stderr.write(f"  {path}:{line}  →  {target}\n")
        return 1
    print(f"OK — {len(files)} markdown files, no broken links.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
