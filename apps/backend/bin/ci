#!/usr/bin/env bash
# Backend CI: lint, format check, module sync, table-access, tests, semgrep.
# Runs from apps/backend/ as cwd. (DI-over-@patch is enforced by ruff TID251.)

set -euo pipefail

cd "$(dirname "$0")/.."

# ruff/pytest/tach/semgrep live in [project.optional-dependencies].dev
# in pyproject.toml. uv run auto-syncs base deps but not extras, so we
# explicitly sync with --extra dev before any `uv run`.
echo "==> uv sync --extra dev"
uv sync --extra dev

echo "==> ruff format --check"
uv run ruff format --check .

echo "==> ruff check"
uv run ruff check .

echo "==> bin/sync_modules (regenerates tach.toml + checks layering)"
bin/sync_modules --check

echo "==> bin/check_table_access"
bin/check_table_access

echo "==> pytest"
mkdir -p tmp
# Clear stale sentinel/dump from any prior run so the post-pytest assertions
# below reflect THIS run, not the previous one. The sentinel is rewritten by
# bin/import_audit.install() at conftest load; the dump is only written when
# violations exist.
rm -f tmp/import_audit_ran tmp/import_audit_violations.json
uv run pytest -q --report-log=tmp/pytest-reportlog.json

# Belt-and-suspenders for the runtime import audit (bin/import_audit.py):
# pytest's sessionfinish hook already exits non-zero on violations, but these
# two checks catch the failure mode where the guard never installed (broken
# conftest, missing import_audit module) — pytest would exit 0 and silently
# leave the audit off. The sentinel proves install() ran; the dump check
# re-surfaces violations after pytest's own output.
test -f tmp/import_audit_ran || { echo "import_audit guard did not run — conftest broken?" >&2; exit 2; }
if [ -s tmp/import_audit_violations.json ]; then
    echo "runtime import audit recorded violations — see tmp/import_audit_violations.json" >&2
    exit 2
fi

echo "==> semgrep (static security: p/python + p/owasp-top-ten)"
# `--error` makes findings fail CI. `--metrics off` disables semgrep.dev
# telemetry. `--exclude` paths bypass the test-scaffolding layer (`app/testing/`
# is excluded from production wheels — see pyproject.toml — and its
# DB-truncate helpers legitimately use raw `text()` that the OWASP rules
# flag) and all unit-test files (they execute against test fixtures, not
# user input). Inline CLI excludes rather than `.semgrepignore` because
# the latter's path resolution proved unreliable across local vs Docker
# environments.
uv run semgrep scan \
    --config p/python \
    --config p/owasp-top-ten \
    --config .semgrep \
    --exclude app/testing \
    --exclude 'test_*.py' \
    --error \
    --metrics off \
    --quiet \
    app

echo "OK"
