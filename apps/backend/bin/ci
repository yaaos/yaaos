#!/usr/bin/env bash
# Backend CI: lint, format check, modularity, table-access, tests, semgrep.
# Runs from apps/backend/ as cwd. (DI-over-@patch is enforced by ruff TID251.)

set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> ruff format --check"
uv run ruff format --check .

echo "==> ruff check"
uv run ruff check .

echo "==> bin/sync_modules (regenerates tach.toml + checks layering)"
bin/sync_modules --check

echo "==> bin/check_table_access"
bin/check_table_access

echo "==> bin/check_doc_links (cross-app docs)"
bin/check_doc_links

echo "==> pytest"
mkdir -p tmp
uv run pytest -q --report-log=tmp/pytest-reportlog.json

echo "==> semgrep (static security: p/python + p/owasp-top-ten)"
# `--error` makes findings fail CI. `--metrics off` disables semgrep.dev
# telemetry. Scans `app/` only — tests rarely surface real issues and burn
# scan time. `.semgrepignore` at repo root excludes vendored/generated paths.
uv run semgrep scan \
    --config p/python \
    --config p/owasp-top-ten \
    --error \
    --metrics off \
    --quiet \
    app

echo "OK"
