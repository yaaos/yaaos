#!/usr/bin/env bash
# Frontend CI: lint + typecheck + tests + build + semgrep.
#
# semgrep must be on PATH. In RWX CI it's pip-installed by the web-ci
# task; locally `pipx install semgrep` (or `pip install --user semgrep`)
# works.

set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> biome check"
pnpm exec biome check src

echo "==> gen-api-types --check (schema drift)"
bin/gen-api-types --check

echo "==> tsc --noEmit"
pnpm exec tsc --noEmit

echo "==> vitest"
mkdir -p tmp
pnpm exec vitest run --reporter=default --reporter=json --outputFile=./tmp/vitest.json

echo "==> vite build"
pnpm exec vite build

echo "==> bundle report (non-gating)"
# rollup-plugin-visualizer wrote tmp/bundle-stats.html during the build above.
# Emit the top-10 chunks by parsed size so CI logs carry a size baseline.
# Never fails — informational only.
node -e "
const fs = require('fs');
const f = 'tmp/bundle-stats.html';
if (!fs.existsSync(f)) { console.log('  bundle-stats.html not found — skipping.'); process.exit(0); }
const s = fs.statSync(f).size;
console.log('  bundle-stats.html written (' + (s / 1024).toFixed(1) + ' KB). Open for interactive treemap.');
" || true

echo "==> dependency-cruiser (layer/domain direction + public-only)"
# Uses the programmatic API directly so it runs from the pnpm workspace.
# Rules live in .dependency-cruiser.cjs; see apps/web/docs/patterns.md.
node bin/check-deps.mjs

echo "==> knip (unused files / exports / dependencies)"
# Project-wide dead-code gate; config in knip.json. Exits non-zero on findings.
pnpm exec knip

echo "==> use-*.tsx hook naming check"
# Logic hooks must be .ts not .tsx — hooks never return JSX.
# Any use-*.tsx file in src/ fails the build.
illegal_hook_files=$(find src -name "use-*.tsx" 2>/dev/null | sort)
if [ -n "$illegal_hook_files" ]; then
  echo "  FAIL: found use-*.tsx files (hooks must be .ts, not .tsx):"
  echo "$illegal_hook_files" | sed 's/^/    /'
  exit 1
fi
echo "  use-*.tsx check: 0 files ✓"

echo "==> semgrep (static security: p/typescript + p/react + p/owasp-top-ten)"
semgrep scan \
    --config p/typescript \
    --config p/react \
    --config p/owasp-top-ten \
    --error \
    --metrics off \
    --quiet \
    src

echo "OK"
