#!/usr/bin/env bash
# Generate TypeScript types from the committed backend OpenAPI spec.
#
# Usage:
#   bin/gen-api-types            — regenerate from apps/backend/openapi/web-api.json
#   bin/gen-api-types --check    — drift check: regenerate then fail if git diff
#
# Source: apps/backend/openapi/web-api.json (relative: ../backend/openapi/web-api.json from apps/web/; committed; /api/testing/* paths excluded).
# Set OPENAPI_URL to override the source with a live server URL (local dev only).
#
# The generated file is committed. Callers import types via
# `apps/web/src/core/api/generated/schema.d.ts`; never import it
# directly from the generated dir in production code — go through
# `@core/api`.

set -euo pipefail

cd "$(dirname "$0")/.."

COMMITTED_SPEC="../backend/openapi/web-api.json"
OUT="src/core/api/generated/schema.d.ts"
CHECK_MODE=false

for arg in "$@"; do
  if [[ "$arg" == "--check" ]]; then
    CHECK_MODE=true
  fi
done

if [[ -n "${OPENAPI_URL:-}" ]]; then
  echo "==> Fetching OpenAPI spec from $OPENAPI_URL"
  TMP=$(mktemp /tmp/openapi.XXXXXX.json)
  trap 'rm -f "$TMP"' EXIT
  curl -sf "$OPENAPI_URL" -o "$TMP"
  SPEC_SOURCE="$TMP"
else
  echo "==> Using committed spec $COMMITTED_SPEC"
  SPEC_SOURCE="$COMMITTED_SPEC"
fi

# Snapshot the committed file before regenerating so the drift check can
# compare without git — the CI workspace is not a git working tree.
if $CHECK_MODE; then
  BEFORE=$(mktemp /tmp/schema.XXXXXX.d.ts)
  trap 'rm -f "${TMP:-}" "$BEFORE"' EXIT
  cp "$OUT" "$BEFORE"
fi

echo "==> Generating $OUT"
mkdir -p "$(dirname "$OUT")"
pnpm exec openapi-typescript "$SPEC_SOURCE" --output "$OUT"

if $CHECK_MODE; then
  echo "==> Checking for drift"
  if ! cmp -s "$BEFORE" "$OUT"; then
    echo "ERROR: Generated types are out of date. Run bin/gen-api-types and commit the result."
    diff -u "$BEFORE" "$OUT" || true
    exit 1
  fi
  echo "OK: no drift"
fi
